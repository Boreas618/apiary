{
  "name": "apiary-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "runArgs": [
    "--security-opt",
    "seccomp=unconfined",
    "--security-opt",
    "label=disable",
    "--cap-add=SYS_ADMIN",
    "--device=/dev/fuse",
    "--cgroupns=private",
    "--tmpfs=/sys/fs/cgroup:rw,mode=755"
  ],
  "containerEnv": {
    "RUST_BACKTRACE": "1"
  },
  "postCreateCommand": "cargo fetch",
  "postStartCommand": "bash .devcontainer/verify-userns.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
